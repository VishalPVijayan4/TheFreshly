<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_fresh_app"
        tools:context=".MainActivity">

        <!-- Fresh top bar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/custom_toolbar"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_fresh_toolbar"
            android:elevation="6dp"
            android:paddingTop="12dp"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">

                <ImageButton
                    android:id="@+id/ivBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#101612" />

                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/open_sans_bold"
                    android:gravity="start|center_vertical"
                    android:text="Freshly"
                    android:textColor="#075D3B"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/threeDotButton"
                    app:layout_constraintStart_toEndOf="@id/ivBack"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Freshly" />

                <TextView
                    android:id="@+id/toolbarSubTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@id/toolbarTitle"
                    app:layout_constraintTop_toBottomOf="@id/toolbarTitle" />

                <ImageButton
                    android:id="@+id/threeDotButton"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_profile_circle"
                    android:contentDescription="Account"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_user"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#075D3B" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.appcompat.widget.Toolbar>


        <!-- Fragment Container -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/navHostFragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:defaultNavHost="true"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/custom_toolbar"
            app:navGraph="@navigation/nav_graph" />

        <!-- Luxury Gold FAB -->
        <!-- Alternative: Gradient FAB Container -->
        <!-- Luxury Gold FAB with Badge -->
        <!-- Luxury Gold FAB -->
        <!-- Alternative: Gradient FAB Container -->
        <FrameLayout
            android:id="@+id/fabContainer"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_view_cart_button"
            android:elevation="12dp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/cart"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="start|center_vertical"
                android:contentDescription="@string/category_image_desc"
                android:src="@drawable/ic_cart"
                app:backgroundTint="@android:color/transparent"
                app:borderWidth="0dp"
                app:elevation="0dp"
                app:fabCustomSize="52dp"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/open_sans_bold"
                android:letterSpacing="0.03"
                android:text="View Cart"
                android:textColor="@android:color/white"
                android:textSize="17sp" />

        </FrameLayout>




        <!-- Luxury Glass Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_view"
            android:layout_width="0dp"
            android:layout_height="76dp"
            android:background="@drawable/bg_fresh_bottom_nav"
            android:elevation="12dp"
            app:itemActiveIndicatorStyle="@style/FreshBottomNavIndicator"
            app:itemIconSize="24dp"
            app:itemIconTint="@color/bottom_nav_fresh_selector"
            app:itemRippleColor="#228AF3B8"
            app:itemTextColor="@color/bottom_nav_fresh_selector"
            app:labelVisibilityMode="labeled"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:menu="@menu/bottom_nav_menu" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
