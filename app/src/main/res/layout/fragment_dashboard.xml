<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".presentation.ui.fragment.DashboardFragment">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out"
        android:background="@drawable/bg_luxury_gradient">

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="@drawable/bg_luxury_gradient">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#F1C40F" />
        </LinearLayout>

        <!-- Error -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:background="@drawable/bg_luxury_gradient">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Something went wrong"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:fontFamily="@font/open_sans_bold"
                android:alpha="0.9" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Retry"
                android:textSize="14sp"
                app:backgroundTint="#F1C40F"
                app:cornerRadius="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Success -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="@drawable/bg_luxury_gradient">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutSuccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="40dp">

                <!-- Header / Profile - Luxury Glass Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_profile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="24dp"
                    android:padding="24dp"
                    android:background="@drawable/bg_luxury_glass"
                    android:elevation="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profilePic"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/circle_dp"
                        app:strokeColor="#33F1C40F"
                        app:strokeWidth="2dp"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/txtGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Good morning"
                        android:textSize="13sp"
                        android:textColor="#E6FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintStart_toEndOf="@id/profilePic"
                        app:layout_constraintTop_toTopOf="@id/profilePic" />

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="2dp"
                        android:text="Vishal"
                        android:textSize="20sp"
                        android:textColor="@android:color/white"
                        android:fontFamily="@font/open_sans_bold"
                        android:letterSpacing="0.02"
                        app:layout_constraintStart_toEndOf="@id/profilePic"
                        app:layout_constraintTop_toBottomOf="@id/txtGreeting" />

                    <TextView
                        android:id="@+id/txtAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:drawableStart="@drawable/ic_location"
                        android:drawableTint="#80F1C40F"
                        android:drawablePadding="8dp"
                        android:text="@string/address"
                        android:textSize="13sp"
                        android:textColor="#D1D5DB"
                        android:fontFamily="sans-serif"
                        app:layout_constraintTop_toBottomOf="@id/profilePic"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Section Title - Gold Accent -->
                <TextView
                    android:id="@+id/txtShopBy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:layout_marginTop="24dp"
                    android:text="Shop by category"
                    android:textSize="22sp"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/open_sans_bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintTop_toBottomOf="@id/cl_profile"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Gold underline for section title -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_luxury_accent"
                    app:layout_constraintTop_toBottomOf="@id/txtShopBy"
                    app:layout_constraintStart_toStartOf="@id/txtShopBy" />

                <!-- Category Grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginTop="24dp"
                    android:nestedScrollingEnabled="false"
                    android:padding="8dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="3"
                    app:layout_constraintTop_toBottomOf="@id/txtShopBy"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:listitem="@layout/item_raw_category" />

                <ProgressBar
                    android:id="@+id/progressbar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="32dp"
                    android:indeterminateTint="#F1C40F"
                    app:layout_constraintTop_toBottomOf="@id/rvCategory"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </ViewFlipper>
</layout>
