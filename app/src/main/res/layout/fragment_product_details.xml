<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".presentation.ui.fragment.ProductDetailsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_fresh_app">

        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_fresh_state_icon"
                android:elevation="6dp">

                <ProgressBar
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#075D3B" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/open_sans_bold"
                android:text="Loading product details"
                android:textColor="#101612"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Fetching fresh product information."
                android:textColor="#6F7772"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="18dp"
            app:layout_constraintBottom_toTopOf="@id/bottomBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvDetailsBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product details"
                    android:textColor="#075D3B"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/open_sans_bold" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:layout_marginTop="18dp"
                    android:background="#F3F6F4"
                    android:scaleType="fitCenter"
                    app:cornerRadius="4dp"
                    tools:src="@drawable/image_icon" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/open_sans_bold"
                    android:gravity="center"
                    android:textColor="#075D3B"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    tools:text="Organic Hass Avocado" />

                <TextView
                    android:id="@+id/tvBrandSku"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="#2D332F"
                    android:textSize="16sp"
                    tools:text="Brand · SKU" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvShipping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_fresh_chip"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:textColor="#075D3B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Ships in 1 month" />

                    <TextView
                        android:id="@+id/tvStockAvailability"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_fresh_soft_chip"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:textColor="#1A241E"
                        android:textSize="14sp"
                        tools:text="98% in stock" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="150dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_fresh_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RATING"
                            android:textColor="#101612"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textColor="#075D3B"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            tools:text="4.8 / 5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="150dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_fresh_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ORDER"
                            android:textColor="#101612"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMOQ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center"
                            android:textColor="#075D3B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="Minimum 24" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:text="Why users trust this product"
                    android:textColor="#101612"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/open_sans_bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_fresh_chip"
                    android:lineSpacingExtra="4dp"
                    android:padding="20dp"
                    android:textColor="#202A24"
                    android:textSize="16sp"
                    tools:text="Sourced directly from certified organic farmers." />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#075D3B"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Category: groceries" />

                <TextView
                    android:id="@+id/tvTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="15sp"
                    tools:text="Tags: beauty, mascara" />

                <TextView
                    android:id="@+id/tvDimensions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="15sp"
                    tools:text="Dimensions and weight" />

                <TextView
                    android:id="@+id/tvWarranty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="15sp"
                    tools:text="Warranty" />

                <TextView
                    android:id="@+id/tvReturnPolicy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="15sp"
                    tools:text="Return policy" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:background="#DDE7E2" />

                <TextView
                    android:id="@+id/tvMetadata"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textColor="#202A24"
                    android:textSize="14sp"
                    tools:text="Created At: ... | Barcode: ..." />

                <TextView
                    android:id="@+id/tvReviewHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Reviews"
                    android:textColor="#101612"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/open_sans_bold" />

                <TextView
                    android:id="@+id/tvReview1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="14sp"
                    tools:text="John (4★): Great" />

                <TextView
                    android:id="@+id/tvReview2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="14sp"
                    tools:text="Jane (5★): Perfect" />

                <TextView
                    android:id="@+id/tvReview3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_fresh_card"
                    android:padding="16dp"
                    android:textColor="#202A24"
                    android:textSize="14sp"
                    tools:text="Lee (3★): Good" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/bottomBar"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:background="@android:color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Price"
                    android:textColor="#101612"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#075D3B"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="$3.50" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_btns"
                android:layout_width="178dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_fresh_pill_dark"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="−"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    app:backgroundTint="#1A7C52"
                    app:cornerRadius="24dp" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="1 item"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="+"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    app:backgroundTint="#1A7C52"
                    app:cornerRadius="24dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd"
                android:layout_width="156dp"
                android:layout_height="58dp"
                android:text="Add to Cart"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="#075D3B"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_cart"
                app:iconTint="@android:color/white" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
