<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="5dp"
    android:layout_margin="5dp"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/tvAppName1"
        android:layout_width="40sp"
        android:layout_height="40sp"
        android:src="@drawable/image_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_selected"
        android:layout_width="20sp"
        android:layout_height="20sp"
        android:layout_margin="10dp"
        android:background="@drawable/selected_radio"
        android:src="@drawable/image_icon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/open_sans_bold"
        android:text="Address Title "
        android:textAlignment="center"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/tvAppName1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tvAppName1"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSubtxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:gravity="center"
        android:fontFamily="@font/open_sans_light"
        android:text="15547, GRB Apartment , Electronic City Near Karaunya Hospital - Electronic City , Bengaluru 560068"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/iv_selected"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtTitle" />

    <View
        android:layout_margin="14dp"
        app:layout_constraintTop_toBottomOf="@+id/txtSubtxt"
        android:layout_width="match_parent"
        android:layout_height="0.7dp"
        android:background="@color/sienna"/>

</androidx.constraintlayout.widget.ConstraintLayout>