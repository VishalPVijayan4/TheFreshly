<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_luxury_glass"
        android:padding="12dp">

        <!-- Product Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgCartProduct"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_luxury_icon"
            app:strokeColor="#33F1C40F"
            app:strokeWidth="1.5dp"
            app:shapeAppearanceOverlay="@style/CircleImageOverlay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:src="@drawable/image_icon" />

        <!-- RIGHT COLUMN (qty + remove) -->
        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgCartProduct"
            app:layout_constraintBottom_toBottomOf="@id/imgCartProduct">

            <!-- Quantity Controls -->
            <LinearLayout
                android:id="@+id/cartItemControls"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_luxury_glass"
                android:paddingHorizontal="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCartDecrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="#33F1C40F"
                    app:cornerRadius="8dp"
                    app:icon="@null" />

                <TextView
                    android:id="@+id/tvCartQuantity"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:fontFamily="@font/open_sans_bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCartIncrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="#33F1C40F"
                    app:cornerRadius="8dp"
                    app:icon="@null" />
            </LinearLayout>

            <!-- Remove button under qty -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCartRemove"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="6dp"
                android:text="Remove"
                android:textSize="11sp"
                android:textColor="#F1C40F"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:strokeColor="#66F1C40F"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- TEXT COLUMN (between image and rightColumn) -->
        <TextView
            android:id="@+id/tvCartProductTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:fontFamily="@font/open_sans_bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/imgCartProduct"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"
            app:layout_constraintTop_toTopOf="@id/imgCartProduct"
            tools:text="Luxury Silk Scarf With Very Long Name" />

        <TextView
            android:id="@+id/tvCartProductBrand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="#E6FFFFFF"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toEndOf="@id/imgCartProduct"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"
            app:layout_constraintTop_toBottomOf="@id/tvCartProductTitle"
            tools:text="Gucci" />

        <TextView
            android:id="@+id/tvCartProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#F1C40F"
            android:fontFamily="@font/open_sans_bold"
            app:layout_constraintStart_toEndOf="@id/imgCartProduct"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"
            app:layout_constraintTop_toBottomOf="@id/tvCartProductBrand"
            app:layout_constraintBottom_toBottomOf="@id/imgCartProduct"
            tools:text="$999" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
