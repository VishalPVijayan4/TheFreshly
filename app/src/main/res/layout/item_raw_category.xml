<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="5dp"
    android:background="@drawable/bg_luxury_glass"
    android:padding="14dp">

    <!-- Glass / dark luxury background layer -->
    <View
        android:id="@+id/luxury_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.96"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Icon -->
    <ImageView
        android:id="@+id/category_image"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/image_icon"
        android:scaleType="centerInside"
        android:background="@drawable/bg_luxury_icon"
        android:padding="8dp"
        app:tint="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Vertical Divider -->
    <View
        android:id="@+id/vertical_divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:background="#33F1C40F"
        app:layout_constraintStart_toEndOf="@id/category_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- TITLE + TAGLINE CHAIN -->

    <!-- Title -->
    <TextView
        android:id="@+id/category_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Beauty"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/vertical_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_goneMarginStart="16dp" />

    <!-- Thin accent line under title -->
    <View
        android:layout_width="52dp"
        android:layout_height="2dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_luxury_accent"
        app:layout_constraintTop_toBottomOf="@id/category_title"
        app:layout_constraintStart_toStartOf="@id/category_title" />

    <!-- Description -->
    <TextView
        android:id="@+id/category_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Unlock your natural glow with premium beauty picks"
        android:textSize="12sp"
        android:textColor="#E6FFFFFF"
        android:fontFamily="sans-serif"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/category_title"
        app:layout_constraintStart_toStartOf="@id/category_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Optional subtle right chevron for navigation hint -->
    <ImageView
        android:id="@+id/luxury_chevron"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_expand_right"
        app:tint="#80F1C40F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/category_title"
        app:layout_constraintBottom_toBottomOf="@id/category_description" />

</androidx.constraintlayout.widget.ConstraintLayout>
